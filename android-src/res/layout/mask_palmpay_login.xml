<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="60dp"
        android:src="@drawable/palmpay_logo_placeholder" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Back!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#490181"
        android:layout_marginTop="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Securely login to your PalmPay account"
        android:textColor="#757575"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/et_palmpay_pin"
        android:layout_width="280dp"
        android:layout_height="65dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="50dp"
        android:background="@drawable/purple_border_input"
        android:gravity="center"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:letterSpacing="2.0"
        android:textSize="30sp"
        android:textColor="#7C3AED" />

    <Button
        android:id="@+id/btn_palmpay_login"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#7C3AED"
        android:text="Next"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Sign up"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="25dp"
        android:textColor="#7C3AED"
        android:textSize="14sp" />
</LinearLayout>

